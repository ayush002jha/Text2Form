        "description": "Click on the first form in the dashboard list"
      },
      {
        "type": "action",
        "description": "Click the \"Edit\" button or \"Edit form\" link on the form page"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Save\" is visible"
      }
    ]
