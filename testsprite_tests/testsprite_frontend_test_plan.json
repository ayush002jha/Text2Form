  {
    "id": "TC003",
    "title": "Generation handles a long, detailed prompt",
    "description": "Verifies the generator can accept a long prompt and still redirect to the editor with multiple generated fields visible.",
    "category": "AI-Powered Form Generation",
    "priority": "Medium",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Type \"Build a job application form for a software engineer role. Collect: full name, email, phone, location, LinkedIn URL, GitHub URL, years of experience (number), primary programming languages (multi-select), preferred start date, salary expectations, work authorization (yes/no), and a short free-text question: 'Tell us about a project you are proud of'. Add a section for availability and whether they are open to relocation.\" into the prompt input textarea"
      },
      {
        "type": "action",
        "description": "Click on \"Create\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard/\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/edit\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Full name\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Years of experience\" is visible"
      }
    ]
  },
