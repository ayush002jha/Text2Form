[
  {
    "id": "TC001",
    "title": "Generate a form from a natural-language prompt and reach the editor",
    "description": "Verifies a user can generate a form from a prompt on the landing page and is redirected to the form editor where generated fields are visible.",
    "category": "AI-Powered Form Generation",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Prompt input textarea\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Create a customer satisfaction survey with 5 questions: overall rating (1-5), what did you like most, what can we improve, would you recommend us (yes/no), and email (optional).\" into the prompt input textarea"
      },
      {
        "type": "action",
        "description": "Click on \"Create\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard/\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/edit\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Overall rating\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Would you recommend\" is visible"
      }
    ]
  },
